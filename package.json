{
  "name": "@dev/monorepo",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "description": "Productivity playground",
  "license": "MIT",
  "author": "Jesse Gibson <JesseTheGibson@gmail.com>",
  "homepage": "https://apps.psychollama.io",
  "repository": "github:PsychoLlama/apps",
  "packageManager": "pnpm@11.4.0",
  "scripts": {
    "prepare": "workspace patch-workerd",
    "build": "turbo run build",
    "cargo:clippy": "cargo clippy --workspace --all-targets -- -D warnings",
    "cargo:test": "cargo test --workspace",
    "check": "turbo run lint cargo:clippy typecheck test cargo:test test:browser knip:dev knip:production fmt-check workspace-check build",
    "dev": "turbo run dev --filter=@app/main",
    "fmt": "treefmt",
    "fmt-check": "treefmt --ci",
    "knip:dev": "knip",
    "knip:production": "knip --production",
    "lint": "eslint --color --cache --cache-location node_modules/.cache/eslint/",
    "preview": "turbo run preview --filter=@app/main",
    "test": "vitest run --project unit",
    "test:browser": "vitest run --project browser",
    "typecheck": "tsc",
    "workspace-check": "node packages/dev/workspace-cli/src/cli.ts check"
  },
  "prettier": {
    "singleQuote": true,
    "trailingComma": "all"
  },
  "devDependencies": {
    "@dev/build": "workspace:*",
    "@dev/vitest-config": "workspace:*",
    "@dev/workspace-cli": "workspace:*",
    "@dev/eslint-plugin": "workspace:*",
    "@eslint/config-helpers": "^0.6.0",
    "@eslint/js": "^10.0.0",
    "@iconify/json": "^2.2.460",
    "@testing-library/jest-dom": "catalog:",
    "@vanilla-extract/css": "catalog:",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "catalog:",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-solid": "^0.14.5",
    "jsdom": "^29.0.1",
    "knip": "catalog:",
    "playwright": "catalog:",
    "prettier": "^3.8.1",
    "solid-js": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "^8.59.0",
    "unplugin-icons": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  }
}
