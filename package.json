{
  "name": "@psychollama/apps",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "description": "Miscellaneous tools",
  "author": "Jesse Gibson <JesseTheGibson@gmail.com>",
  "homepage": "https://apps.psychollama.io",
  "repository": "github:PsychoLlama/apps",
  "scripts": {
    "dev": "pnpm --filter @psychollama/web dev",
    "build": "pnpm --filter @psychollama/web build",
    "storybook": "pnpm --filter @psychollama/web storybook",
    "storybook:build": "pnpm --filter @psychollama/web storybook:build",
    "typecheck": "tsc && pnpm -r typecheck",
    "knip": "pnpm --filter @psychollama/web knip",
    "lint": "eslint --color",
    "test": "vitest run",
    "test:storybook": "pnpm --filter @psychollama/web test:storybook"
  },
  "prettier": {
    "singleQuote": true,
    "trailingComma": "all"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "esbuild",
      "sharp",
      "workerd"
    ]
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.4",
    "@eslint/js": "^9.39.2",
    "@psychollama/eslint-plugin": "workspace:*",
    "@testing-library/jest-dom": "^6.9.1",
    "@vanilla-extract/css": "^1.18.0",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^9.39.2",
    "eslint-plugin-solid": "^0.14.5",
    "jsdom": "^29.0.1",
    "knip": "^6.4.1",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^7.0.0",
    "vitest": "^4.1.4"
  }
}
