# Route the @lib and @app scopes to a non-resolvable registry so private
# workspace packages can't be silently hijacked by a published impostor
# (the "dependency confusion" attack). Any @lib/* or @app/* dep that isn't
# a workspace package fails loudly at install time instead of fetching
# from npm. .invalid is an RFC 2606 reserved TLD — guaranteed never to
# resolve.
@lib:registry=https://registry.invalid
@app:registry=https://registry.invalid

# Default `pnpm add` to workspace:* for in-repo packages.
save-workspace-protocol=true
