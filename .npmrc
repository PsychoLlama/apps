# Route the private workspace scopes to a non-resolvable registry so
# packages can't be silently hijacked by a published impostor (the
# "dependency confusion" attack). Any @lib/*, @app/*, @dev/*, or @crate/*
# dep that isn't a workspace package fails loudly at install time instead
# of fetching from npm. .invalid is an RFC 2606 reserved TLD — guaranteed
# never to resolve.
@lib:registry=https://registry.invalid
@app:registry=https://registry.invalid
@dev:registry=https://registry.invalid
@crate:registry=https://registry.invalid
