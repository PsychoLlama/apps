{
  "name": "@lib/holz-idb-backend",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "description": "IndexedDB persistence backend for holz logs, usable from the main thread, workers, and service workers.",
  "license": "MIT",
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts",
    "./broadcast": "./src/broadcast.ts",
    "./database": "./src/database.ts"
  },
  "scripts": {
    "typecheck": "tsc",
    "test:browser": "chromium-lock vitest run --config vitest.browser.config.ts"
  },
  "dependencies": {
    "@holz/core": "catalog:",
    "@lib/holz-valve": "workspace:*",
    "@lib/messaging": "workspace:*",
    "idb": "catalog:"
  },
  "devDependencies": {
    "@dev/vitest-config": "workspace:*"
  }
}
