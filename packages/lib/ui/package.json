{
  "name": "@lib/ui",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "description": "Shared component library.",
  "license": "MIT",
  "sideEffects": [
    "**/*.css.ts"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./gallery": "./src/gallery/manifest.ts",
    "./props/*": "./src/props/*.ts",
    "./package.json": "./package.json"
  },
  "imports": {
    "#gallery": "./src/gallery/manifest.ts",
    "#gallery/style": "./src/gallery/style.css.ts"
  },
  "scripts": {
    "typecheck": "tsc",
    "test:browser": "chromium-lock vitest run --config vitest.browser.config.ts"
  },
  "dependencies": {
    "@lib/design": "workspace:*",
    "@vanilla-extract/css": "catalog:",
    "@vanilla-extract/dynamic": "catalog:"
  },
  "devDependencies": {
    "@dev/vitest-config": "workspace:*",
    "@lib/gallery": "workspace:*",
    "@solidjs/router": "catalog:",
    "@solidjs/testing-library": "catalog:",
    "solid-js": "catalog:"
  },
  "peerDependencies": {
    "@solidjs/router": "*",
    "solid-js": "*"
  }
}
