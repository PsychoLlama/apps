{
  "name": "@lib/observability",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "description": "Structured logging built on @holz/core.",
  "license": "MIT",
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts",
    "./config": "./src/config.ts"
  },
  "imports": {
    "#processor": {
      "browser": "./src/logging/processor.browser.ts",
      "default": "./src/logging/processor.server.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc"
  },
  "dependencies": {
    "@holz/ansi-terminal-backend": "0.8.3-rc.179",
    "@holz/console-backend": "0.8.3-rc.179",
    "@holz/core": "catalog:",
    "@holz/env-filter": "0.8.3-rc.179",
    "@holz/log-collector": "catalog:",
    "@holz/stream-backend": "0.8.3-rc.179",
    "@lib/holz-config-filter": "workspace:*",
    "@lib/holz-idb-backend": "workspace:*",
    "@lib/runtime-config": "workspace:*"
  }
}
