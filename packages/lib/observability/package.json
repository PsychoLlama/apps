{
  "name": "@lib/observability",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "description": "Structured logging built on @holz/core.",
  "license": "MIT",
  "sideEffects": [
    "./src/worker/index.ts"
  ],
  "exports": "./src/index.ts",
  "imports": {
    "#processor": {
      "browser": "./src/logging/processor.browser.ts",
      "default": "./src/logging/processor.server.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc && tsc -p src/worker/tsconfig.json"
  },
  "dependencies": {
    "@holz/ansi-terminal-backend": "0.8.3-rc.155",
    "@holz/console-backend": "0.8.3-rc.155",
    "@holz/core": "0.8.3-rc.155",
    "@holz/env-filter": "0.8.3-rc.155",
    "@holz/json-backend": "0.8.3-rc.155",
    "@holz/log-collector": "catalog:",
    "@holz/stream-backend": "0.8.3-rc.155",
    "@lib/messaging": "workspace:*"
  }
}
