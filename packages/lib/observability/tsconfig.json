{
  "extends": "../../../tsconfig.web.json",
  "compilerOptions": {
    "types": ["node", "vite/client", "vitest/globals"]
  },
  // Worker entrypoints are typed for the worker global scope, not the DOM —
  // see `src/worker/tsconfig.json`. Excluded here so `self` resolves as a
  // `DedicatedWorkerGlobalScope` there instead of a `Window` here.
  "exclude": ["src/worker"]
}
