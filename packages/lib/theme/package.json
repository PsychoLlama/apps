{
  "name": "@lib/theme",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "description": "Pre-composed color palettes using `@lib/design`.",
  "license": "MIT",
  "sideEffects": [
    "**/*.css.ts"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./catalog": "./src/catalog.ts",
    "./swatch": "./src/swatch.css.ts",
    "./default": "./src/bundles/blue.css.ts",
    "./bundles/*": "./src/bundles/*.css.ts",
    "./package.json": "./package.json"
  },
  "scripts": {
    "typecheck": "tsc"
  },
  "dependencies": {
    "@lib/design": "workspace:*",
    "@lib/state": "workspace:*"
  },
  "peerDependencies": {
    "@solidjs/meta": "*",
    "solid-js": "*"
  }
}
