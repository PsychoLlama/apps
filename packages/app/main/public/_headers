# Long-cache content-addressed bundles. Vite hashes every emitted
# entry, chunk, and asset under `_build/` — `assertHashedAssetNames`
# in `vite.config.ts` fails the build if a future config tweak ever
# drops `[hash]` from the output templates, so this prefix is safe
# to mark `immutable`.
#
# `Service-Worker-Allowed: /` widens the scope of the bundled
# service worker (which Vite emits under `/_build/` with a hashed
# name) past its default directory scope. The header is harmless on
# non-SW responses.
#
# Everything else inherits Cloudflare's default
# `Cache-Control: public, max-age=0, must-revalidate`, which keeps
# HTML shells (and anything else not under `_build/`) revalidating
# every request.

/_build/*
  Cache-Control: public, max-age=31536000, immutable
  Service-Worker-Allowed: /

# The PWA manifest emits as a hashed asset under `_build/assets/`.
# Cloudflare guesses `application/octet-stream` for `.webmanifest`,
# but Chrome rejects the manifest if the response Content-Type
# isn't `application/manifest+json` (or `application/json`).
/_build/assets/*.webmanifest
  Content-Type: application/manifest+json
