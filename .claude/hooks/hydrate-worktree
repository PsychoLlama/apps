#!/usr/bin/env bash
# Hydrate a freshly-created git worktree by running `pnpm install` if
# node_modules is missing. Skips the main checkout, where the developer
# manages deps directly.
#
# Turbo handles its own cache sharing across worktrees natively — no
# symlinking required.

set -euo pipefail

cd "${CLAUDE_PROJECT_DIR:-.}"

# In a linked worktree, `.git` is a file pointing at the gitdir.
# In the main checkout it's a directory. Bail if we're not in a worktree.
[[ -f .git ]] || exit 0

[[ -d node_modules ]] && exit 0

echo 'hydrating worktree: pnpm install...' >&2
pnpm install
